# ================================================================
#  TTC Collision Risk System — .gitignore
# ================================================================

# ---------- Python virtual environments ----------
ttc_env/
.venv/
env/

# ---------- Python cache / compiled files ----------
__pycache__/
*.pyc
*.pyo

# ---------- Jupyter notebook checkpoints ----------
.ipynb_checkpoints/

# ---------- Logs and runtime data ----------
LOGS/*.csv
LOGS/live_data.txt
*.log
*.tmp

# ---------- Streamlit cache and config ----------
.streamlit/

# ---------- OS generated files ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Editor / IDE settings ----------
.vscode/
.idea/
*.swp
*.swo

# ---------- Build / distribution ----------
build/
dist/
*.egg-info/
